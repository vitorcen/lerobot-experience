+def _extract_legacy_norm_stats(
+    pretrained_path: str,
+    policy_cfg: PreTrainedConfig,
+) -> dict[str, dict[str, torch.Tensor]] | None:
+    """Reconstruct dataset_stats from normalize_* buffers baked into a legacy model.safetensors.
+
+    Older lerobot checkpoints (e.g. lerobot/diffusion_pusht) carry normalization params inside
+    the policy state dict under keys like `normalize_inputs.buffer_observation_image.mean`.
+    Newer code expects an external policy_preprocessor.json. When that file is missing on the
+    Hub, we materialize stats from these legacy buffers so a fresh processor can be built.
+
+    Returns None if no legacy buffers are found.
+    """
+    from pathlib import Path
+
+    from huggingface_hub import hf_hub_download
+    from safetensors import safe_open
+
+    model_path = Path(pretrained_path)
+    if model_path.is_dir():
+        st_path = model_path / "model.safetensors"
+        if not st_path.exists():
+            return None
+        st_path = str(st_path)
+    else:
+        try:
+            st_path = hf_hub_download(repo_id=str(pretrained_path), filename="model.safetensors")
+        except Exception:
+            return None
+
+    feature_names = list({**policy_cfg.input_features, **policy_cfg.output_features}.keys())
+    # Legacy code keyed buffers by feature name with dots replaced by underscores.
+    feat_by_buffer = {name.replace(".", "_"): name for name in feature_names}
+
+    stats: dict[str, dict[str, torch.Tensor]] = {}
+    with safe_open(st_path, framework="pt") as f:
+        for key in f.keys():
+            parts = key.split(".")
+            # Match `<normalize_inputs|normalize_targets|unnormalize_outputs>.buffer_<feat>.<stat>`
+            if len(parts) != 3 or not parts[1].startswith("buffer_"):
+                continue
+            if parts[0] not in {"normalize_inputs", "normalize_targets", "unnormalize_outputs"}:
+                continue
+            stat_name = parts[2]
+            if stat_name not in {"mean", "std", "min", "max"}:
+                continue
+            buffer_feat = parts[1][len("buffer_") :]
+            feat = feat_by_buffer.get(buffer_feat)
+            if feat is None:
+                continue
+            stats.setdefault(feat, {})[stat_name] = f.get_tensor(key)
+
+    return stats or None
+
